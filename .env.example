# ----------------------------
# Public client-side env vars
# ----------------------------
# Safe to expose in browser bundle
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Legacy alias used by current client code (set same as anon key)
VITE_SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY

# Optional client API endpoint override
VITE_PAYMENT_API_URL=/api/payment

# -----------------------------------
# Server-only env vars (DO NOT expose)
# -----------------------------------
# Set these in Vercel Project -> Settings -> Environment Variables
PAYTR_MERCHANT_ID=YOUR_PAYTR_MERCHANT_ID
PAYTR_MERCHANT_KEY=YOUR_PAYTR_MERCHANT_KEY
PAYTR_MERCHANT_SALT=YOUR_PAYTR_MERCHANT_SALT
PAYTR_PUBLIC_BASE_URL=https://YOUR_DOMAIN.com
PAYTR_TEST_MODE=1

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
